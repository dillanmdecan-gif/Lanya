# ================================================================
# EXPIRYRANGE BOT v2 — Railway Environment Variables
# Set these in Railway → Service → Variables tab
# ================================================================

# ── REQUIRED ────────────────────────────────────────────────────
DERIV_API_TOKEN=3nMoTkW49VHJqhH
DERIV_APP_ID=1089

# ── SYMBOL ──────────────────────────────────────────────────────
SYMBOL=1HZ10V

# ── ENTRY GATE ──────────────────────────────────────────────────
# Minimum P(win) required to place a trade
MIN_P_WIN=0.85
# Minimum expected value per dollar staked
MIN_EV=0.02
# Ticks required before estimator is trusted
MIN_WARMUP_TICKS=60

# ── VOLATILITY REGIME THRESHOLDS ────────────────────────────────
# σ below this = CALM regime
SIGMA_CALM=0.080
# σ below this = NORMAL regime (above = ACTIVE, blocked)
SIGMA_NORMAL=0.120

# ── KELLY SIZING ────────────────────────────────────────────────
# Fractional Kelly multiplier (0.25 = quarter Kelly)
KELLY_FRACTION=0.25
# Maximum stake as % of balance
KELLY_MAX_PCT=0.05

# ── MARTINGALE ──────────────────────────────────────────────────
MARTINGALE_BASE_STAKE=0.35
MARTINGALE_FACTOR=2.5
MARTINGALE_MAX_STEPS=3

# ── SESSION LIMITS ───────────────────────────────────────────────
TARGET_PROFIT=50.0
STOP_LOSS=20.0
# Seconds between trade attempts
TRADE_COOLDOWN=10

# ── SETTLEMENT POLLER ────────────────────────────────────────────
# How often the poller checks contract status (seconds)
POLL_INTERVAL=5

# ── PORT (Railway sets this automatically — do not change) ───────
PORT=8080
